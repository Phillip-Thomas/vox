{
  "name": "paravoxia-state-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "vitest run",
    "verify": "npm run typecheck && npm run test && npm run build",
    "migrate": "tsx scripts/migrate.ts",
    "smoke:room": "tsx scripts/smokeRoom.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@neondatabase/serverless": "latest",
    "firebase-admin": "latest",
    "ws": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/ws": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

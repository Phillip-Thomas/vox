PORT=8080
NODE_ENV=development

# Comma-separated allowed browser origins for lobby HTTP requests.
# Leave empty in local dev to allow all origins.
PARAVOXIA_ALLOWED_ORIGINS=http://localhost:5173,https://paravoxia.com

# Local-only bypass for state-server development. Do not enable in deployed environments.
PARAVOXIA_AUTH_DISABLED=false

# Firebase Admin verification.
# In Cloud Run, prefer Application Default Credentials via the service account.
FIREBASE_PROJECT_ID=paravox-game
# Optional local credentials path:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Neon Postgres. Optional until persistence is enabled.
DATABASE_URL=

{
  "name": "voxel-game",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@react-three/drei": "^10.2.0",
    "@react-three/fiber": "^9.1.2",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.1.0",
    "firebase": "^12.15.0",
    "n8ao": "^1.10.2",
    "postprocessing": "^6.38.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.5.2",
    "playwright-core": "^1.61.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run test && npm run build",
    "atlas:smoke": "node tools/procedural-atlas.mjs --mode=smoke",
    "atlas:showcase": "node tools/procedural-atlas.mjs --mode=showcase",
    "atlas:baseline": "node tools/procedural-atlas.mjs --mode=baseline",
    "atlas:perf": "node tools/procedural-atlas.mjs --mode=perf"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "pointerlock-controls",
    "game",
    "minecraft"
  ],
  "description": "Mini Minecraft implementation."
}
